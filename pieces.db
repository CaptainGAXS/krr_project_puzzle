material(4l, dirt).
bit(4l, 0, 0, 0).	bit(4l, 1, 0, 0).	bit(4l, 2, 0, 0).
bit(4l, 0, 1, 0).

% - - -
material(4t, dirt).
bit(4t, 0, 0, 0).	bit(4t, 1, 0, 0).	bit(4t, 2, 0, 0).
					bit(4t, 1, 1, 0).

% - - -
material(4o, dirt).
bit(4o, 0, 0, 0).	bit(4o, 1, 0, 0).
bit(4o, 0, 1, 0).	bit(4o, 1, 1, 0).

% - - -
material(4s, dirt).
bit(4s, 0, 0, 0).	bit(4s, 1, 0, 0).
					bit(4s, 1, 1, 0).	bit(4s, 2, 1, 0).

% - - -
material(4y1, dirt).
bit(4y1, 0, 0, 0).	bit(4y1, 1, 0, 0).
					bit(4y1, 1, 1, 0).

